{{ define "slack.title" }}
[{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}] {{ .CommonLabels.alertname }}
{{ end }}

{{ define "slack.text" }}
{{ range .Alerts }}
*Alert:* {{ .Annotations.summary }}
*Severity:* {{ .Labels.severity }}
*Description:* {{ .Annotations.description }}
*Started:* {{ .StartsAt.Format "2006-01-02 15:04:05 MST" }}
{{ if .Annotations.runbook_url }}*Runbook:* {{ .Annotations.runbook_url }}{{ end }}
{{ if .Annotations.dashboard_url }}*Dashboard:* {{ .Annotations.dashboard_url }}{{ end }}
---
{{ end }}
{{ end }}

{{ define "email.html" }}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
    }
    .critical { background: #ffebee; border-left: 4px solid #f44336; }
    .high { background: #fff3e0; border-left: 4px solid #ff9800; }
    .warning { background: #fffde7; border-left: 4px solid #ffeb3b; }
    .info { background: #e8f5e9; border-left: 4px solid #4caf50; }
    .alert-item {
      background: #f5f5f5;
      padding: 15px;
      margin: 10px 0;
      border-radius: 4px;
    }
    .alert-title {
      font-weight: bold;
      color: #1976d2;
    }
    .label {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 12px;
      font-weight: bold;
      margin: 2px;
    }
    .label-critical { background: #f44336; color: white; }
    .label-high { background: #ff9800; color: white; }
    .label-warning { background: #ffeb3b; color: black; }
    .label-info { background: #4caf50; color: white; }
    .footer {
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid #ddd;
      font-size: 12px;
      color: #666;
    }
    .button {
      display: inline-block;
      padding: 10px 20px;
      background: #1976d2;
      color: white;
      text-decoration: none;
      border-radius: 4px;
      margin: 5px 5px 5px 0;
    }
  </style>
</head>
<body>
  <div class="header {{ .CommonLabels.severity }}">
    <h2>
      {{ if eq .Status "firing" }}🔥{{ else }}✅{{ end }}
      [{{ .Status | toUpper }}] {{ .CommonLabels.alertname }}
    </h2>
    <p>
      <strong>Alerts:</strong> {{ .Alerts | len }} |
      <strong>Severity:</strong> 
      <span class="label label-{{ .CommonLabels.severity }}">{{ .CommonLabels.severity }}</span> |
      <strong>Time:</strong> {{ .StartsAt.Format "2006-01-02 15:04:05 MST" }}
    </p>
  </div>

  {{ range .Alerts }}
  <div class="alert-item">
    <div class="alert-title">{{ .Annotations.summary }}</div>
    <p>{{ .Annotations.description }}</p>
    
    {{ if .Labels.instance }}
    <p><strong>Instance:</strong> <code>{{ .Labels.instance }}</code></p>
    {{ end }}
    
    {{ if .Annotations.runbook_url }}
    <a href="{{ .Annotations.runbook_url }}" class="button">📖 View Runbook</a>
    {{ end }}
    
    {{ if .Annotations.dashboard_url }}
    <a href="{{ .Annotations.dashboard_url }}" class="button">📊 View Dashboard</a>
    {{ end }}
    
    <p><small>
      <strong>Started:</strong> {{ .StartsAt.Format "2006-01-02 15:04:05 MST" }}
      {{ if .EndsAt }}<br><strong>Resolved:</strong> {{ .EndsAt.Format "2006-01-02 15:04:05 MST" }}{{ end }}
    </small></p>
  </div>
  {{ end }}

  <div class="footer">
    <p>
      <strong>7zi-frontend Monitoring System</strong><br>
      This is an automated alert from Prometheus Alertmanager.<br>
      Environment: {{ .CommonLabels.environment }} | Monitor: {{ .CommonLabels.monitor }}
    </p>
  </div>
</body>
</html>
{{ end }}
